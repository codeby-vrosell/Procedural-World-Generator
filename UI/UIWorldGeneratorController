    public class HoverFadeElement : MonoBehaviour, IPointerEnterHandler, IPointerExitHandler {

        [HideInInspector] public float maxAlpha = 1f;
        [HideInInspector] public float fadeSpeed = 5f;

        private Image img;

        private Coroutine fadeCoroutine;

        private void Awake() {

            img = GetComponent<Image>();
            
            if (img != null) {

                Color startColor = img.color;

                startColor.a = 0f;

                img.color = startColor;

            }

        }

        public void OnPointerEnter(PointerEventData eventData) {

            if (img == null) {

                return;

            }
            
            if (fadeCoroutine != null) {

                StopCoroutine(fadeCoroutine);

            }
            
            fadeCoroutine = StartCoroutine(fadeAlpha(maxAlpha));

        }

        public void OnPointerExit(PointerEventData eventData) {

            if (img == null) {

                return;

            }

            if (fadeCoroutine != null) {

                StopCoroutine(fadeCoroutine);

            }

            fadeCoroutine = StartCoroutine(fadeAlpha(0f));

        }

        private IEnumerator fadeAlpha(float targetAlpha) {

            Color c = img.color;
            
            while (Mathf.Approximately(c.a, targetAlpha) == false) {

                c.a = Mathf.MoveTowards(c.a, targetAlpha, Time.deltaTime * fadeSpeed);

                img.color = c;

                yield return null;

            }
            
            c.a = targetAlpha;

            img.color = c;

        }

    }

    private List<TMP_InputField> getFieldsToFormat() {

        List<TMP_InputField> fields = new List<TMP_InputField> {

            biomeSizeInput, minGroupSeparationInput, size1SpawnWeightInput,
            size2SpawnWeightInput, size3SpawnWeightInput, size4SpawnWeightInput,
            minSeparationInput, minSameSeparationInput, traderSpacingInput,
            goblinSpacingInput, bonfireSpacingInput, chestSpacingInput,
            slimeSpacingInput, mimicSpacingInput

        };

        foreach (var ew in individualEnemyWeights) {

            if (ew.weightInput != null) {

                fields.Add(ew.weightInput);

            }

        }
        
        return fields;

    }

    private void setupInputFormattingEvents() {

        foreach (var field in getFieldsToFormat()) {

            if (field != null) {

                field.onEndEdit.AddListener((text) => {

                    formatInputText(field);

                    triggerAutoGenerate();

                });

            }

        }

    }

    private void refreshAllInputFormats() {

        foreach (var field in getFieldsToFormat()) {

            if (field != null) {

                formatInputText(field);

            }

        }

    }

    private void formatInputText(TMP_InputField inputField) {

        if (inputField == null) {

            return;

        }
        
        if (string.IsNullOrEmpty(inputField.text)) {

            return;

        }

        if (inputField == biomeSizeInput) {

            if (float.TryParse(inputField.text, out float floatResult)) {

                inputField.text = floatResult.ToString("00.###");

            }

        }

        else {

            if (int.TryParse(inputField.text, out int intResult)) {

                inputField.text = intResult.ToString("D2");

            }

        }

    }

