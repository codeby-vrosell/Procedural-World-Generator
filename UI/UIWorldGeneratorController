    private void updateHoverLegend() {

        if (hoverLegendText == null) {

            return;

        }
        
        if (GridManager.Instance == null) {

            return;

        }
        
        if (biomeGenerator == null) {

            return;

        }

        if (Application.isFocused == false) {

            hoverLegendText.text = "";
            return;

        }
        
        if (isPointerOverUI()) {

            hoverLegendText.text = "";
            return;

        }

        Ray ray = Camera.main.ScreenPointToRay(Input.mousePosition);

        Plane groundPlane = new Plane(Vector3.up, Vector3.zero);

        if (groundPlane.Raycast(ray, out float enter)) {

            Vector3 hitPoint = ray.GetPoint(enter);

            Vector2Int gridPos = GridManager.Instance.worldToGridPosition(hitPoint);

            if (GridManager.Instance.tryGetCells(gridPos, out Cell cell)) {

                if (cell != null) {

                    string className = "Cell";
                    string typeName = "Unknown";
                    string biomeName = "Unknown";

                    BiomeConfig biome = biomeGenerator.getBiomeConfigAt(gridPos);

                    if (biome != null) {

                        biomeName = biome.name;

                    }

                    bool foundDynamicOccupant = false;

                    if (GridStateManager.Instance != null) {

                        var state = GridStateManager.Instance.getEnemyStateAt(gridPos);

                        if (state != null) {

                            if (state.isDead == false) {

                                if (state.enemyType != null) {

                                    if (state.enemyType.isEnemy) {

                                        className = "Enemy";

                                    }

                                    else {

                                        className = "Entity";

                                    }

                                    typeName = state.enemyType.tileName;

                                    foundDynamicOccupant = true;

                                }

                            }

                        }

                    }

                    if (foundDynamicOccupant == false) {

                        BiomeCellData data = biomeGenerator.getBiomeDataAt(gridPos);

                        if (data.entityType != null) {

                            className = "Entity";

                            typeName = data.entityType.tileName;

                        }

                        else {

                            if (cell.tileType != null) {

                                if (data.groundType != null) {

                                    if (cell.tileType.name != data.groundType.name) {

                                        className = "Obstacle";

                                        typeName = cell.tileType.tileName;

                                    }

                                    else {

                                        className = "Cell";

                                        if (cell.tileType.isWater) {

                                            typeName = "Water";

                                        }

                                        else {

                                            typeName = "Ground";

                                        }

                                    }

                                }

                                else {

                                    className = "Cell";

                                    if (cell.tileType.isWater) {

                                        typeName = "Water";

                                    }

                                    else {

                                        typeName = "Ground";

                                    }

                                }

                            }

                        }

                    }

                    hoverLegendText.text = className + " | " + typeName + " | " + biomeName + " | " + gridPos.x + "," + gridPos.y;

                }

                else {

                    hoverLegendText.text = "";

                }

            }

            else {

                hoverLegendText.text = "";

            }

        }

    }

    private bool isPointerOverUI() {

        if (EventSystem.current != null) {

            return EventSystem.current.IsPointerOverGameObject();

        }

        return false;

    }

    private IEnumerator pulseControls() {

        while (true) {

            if (controlsCanvasGroup != null) {

                float t = Mathf.PingPong(Time.time * pulseSpeed, 1f);

                controlsCanvasGroup.alpha = Mathf.Lerp(minPulseOpacity, maxPulseOpacity, t);

            }

            yield return null;

        }

    }

    private void hideControlsPanel() {

        isControlsActive = false;

        if (pulseCoroutine != null) {

            StopCoroutine(pulseCoroutine);

            pulseCoroutine = null;

        }

        if (controlsPanel != null) {

            controlsPanel.SetActive(false);

        }

    }

    // ============================================================
    // Alpha Fades & Hover Interactions
    // ============================================================

    private void setupFadeHoverImages() {

        if (hoverFadeImages == null) {

            return;

        }

        foreach (Image img in hoverFadeImages) {

            if (img == null) {

                continue;

            }

            HoverFadeElement hoverElement = img.gameObject.GetComponent<HoverFadeElement>();

            if (hoverElement == null) {

                hoverElement = img.gameObject.AddComponent<HoverFadeElement>();

            }

            hoverElement.maxAlpha = maxHoverAlpha;

            hoverElement.fadeSpeed = hoverFadeSpeed;

        }

    }

    private void startAlphaFade(Image img, float targetAlpha) {

        if (activeAlphaFades.ContainsKey(img)) {

            if (activeAlphaFades[img] != null) {

                StopCoroutine(activeAlphaFades[img]);

            }

        }

        activeAlphaFades[img] = StartCoroutine(fadeImageAlpha(img, targetAlpha));

    }

    private IEnumerator fadeImageAlpha(Image img, float targetAlpha) {

        Color c = img.color;

        while (Mathf.Approximately(c.a, targetAlpha) == false) {

            c.a = Mathf.MoveTowards(c.a, targetAlpha, Time.deltaTime * hoverFadeSpeed);

            img.color = c;

            yield return null;

        }

        c.a = targetAlpha;

        img.color = c;

    }

    private void setupButtonHover(Button btn, Color hoverTextColor) {

        if (btn == null) {

            return;

        }

        btn.transition = Selectable.Transition.None;

        TMP_Text btnText = btn.GetComponentInChildren<TMP_Text>();

        if (btnText == null) {

            return;

        }

        Color originalTextColor = btnText.color;

        EventTrigger trigger = btn.gameObject.GetComponent<EventTrigger>();

        if (trigger == null) {

            trigger = btn.gameObject.AddComponent<EventTrigger>();

        }

        System.Action setHoverState = () => {

            btnText.color = hoverTextColor;

        };

        System.Action resetToNormal = () => {

            btnText.color = originalTextColor;

        };

        EventTrigger.Entry entryEnter = new EventTrigger.Entry();

        entryEnter.eventID = EventTriggerType.PointerEnter;

        entryEnter.callback.AddListener((data) => {

            if (btn.interactable) {

                setHoverState();

            }

        });

        trigger.triggers.Add(entryEnter);

        EventTrigger.Entry entryExit = new EventTrigger.Entry();

        entryExit.eventID = EventTriggerType.PointerExit;

        entryExit.callback.AddListener((data) => {

            resetToNormal();

        });

        trigger.triggers.Add(entryExit);

        EventTrigger.Entry entryClick = new EventTrigger.Entry();

        entryClick.eventID = EventTriggerType.PointerClick;

        entryClick.callback.AddListener((data) => {

            resetToNormal();

            if (EventSystem.current != null) {

                EventSystem.current.SetSelectedGameObject(null);

            }

            StartCoroutine(checkHoverAfterEnable(btn, setHoverState));

        });

        trigger.triggers.Add(entryClick);

    }

