    private void setupAutoGenerateButton() {

        if (autoGenerateButton == null) {

            return;

        }

        EventTrigger trigger = autoGenerateButton.gameObject.GetComponent<EventTrigger>();

        if (trigger != null) {

            Destroy(trigger);

        }

        trigger = autoGenerateButton.gameObject.AddComponent<EventTrigger>();

        autoGenerateButton.transition = Selectable.Transition.None;

        TMP_Text btnText = autoGenerateButton.GetComponentInChildren<TMP_Text>();

        if (btnText == null) {

            return;

        }

        Color originalTextColor = btnText.color;

        autoGenerateButton.onClick.RemoveAllListeners();

        autoGenerateButton.onClick.AddListener(() => {

            if (isAutoGenerateEnabled) {

                isAutoGenerateEnabled = false;

            }

            else {

                isAutoGenerateEnabled = true;

            }

            if (isAutoGenerateEnabled) {

                btnText.color = autoGenerateActiveTextColor;

            }

            else {

                btnText.color = autoGenerateActiveTextColor;

            }

            if (EventSystem.current != null) {

                EventSystem.current.SetSelectedGameObject(null);

            }

        });

        EventTrigger.Entry entryEnter = new EventTrigger.Entry();

        entryEnter.eventID = EventTriggerType.PointerEnter;

        entryEnter.callback.AddListener((data) => {

            if (autoGenerateButton.interactable) {

                btnText.color = autoGenerateActiveTextColor;

            }

        });

        trigger.triggers.Add(entryEnter);

        EventTrigger.Entry entryExit = new EventTrigger.Entry();

        entryExit.eventID = EventTriggerType.PointerExit;

        entryExit.callback.AddListener((data) => {

            if (isAutoGenerateEnabled) {

                btnText.color = autoGenerateActiveTextColor;

            } 

            else {

                btnText.color = originalTextColor;

            }

        });

        trigger.triggers.Add(entryExit);

    }

    // ============================================================
