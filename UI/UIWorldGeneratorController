    private void linkFoldButton(Button button, GameObject container) {

        if (button != null) {

            if (container != null) {

                RectTransform btnRect = button.GetComponent<RectTransform>();

                if (btnRect != null) {

                    float initialZ = 0f;

                    if (container.activeSelf) {

                        initialZ = 180f;

                    }

                    btnRect.localEulerAngles = new Vector3(0, 0, initialZ);

                }

                button.onClick.AddListener(() => {

                    bool isUnfolding = false;

                    if (container.activeSelf == false) {

                        isUnfolding = true;

                    }
                    
                    container.SetActive(isUnfolding);

                    if (btnRect != null) {

                        float targetZ = 0f;

                        if (isUnfolding) {

                            targetZ = 180f;

                        }

                        if (activeRotations.ContainsKey(btnRect)) {

                            if (activeRotations[btnRect] != null) {

                                StopCoroutine(activeRotations[btnRect]);

                            }

                        }

                        activeRotations[btnRect] = StartCoroutine(smoothRotateButton(btnRect, targetZ, 0.2f));

                    }

                });

            }

        }

    }

    private IEnumerator smoothRotateButton(RectTransform rect, float targetZ, float duration) {

        Quaternion startRot = rect.localRotation;

        Quaternion endRot = Quaternion.Euler(0, 0, targetZ);

        float time = 0;

        while (time < duration) {

            rect.localRotation = Quaternion.Lerp(startRot, endRot, time / duration);

            time = time + Time.deltaTime;

            yield return null;

        }

        rect.localRotation = endRot;

    }

