    private void setupSectionToggle(Toggle toggle, Button foldButton, GameObject container) {

        if (toggle == null) {

            return;

        }

        if (container != null) {

            container.SetActive(toggle.isOn);

        }
        
        if (foldButton != null) {

            foldButton.interactable = toggle.isOn;

        }

        toggle.onValueChanged.AddListener((isOn) => {

            if (container != null) {

                container.SetActive(isOn);

            }

            if (foldButton != null) {

                foldButton.interactable = isOn;

                RectTransform btnRect = foldButton.GetComponent<RectTransform>();

                if (btnRect != null) {

                    float targetZ = 0f;

                    if (isOn) {

                        targetZ = 180f;

                    }

                    if (activeRotations.ContainsKey(btnRect)) {

                        if (activeRotations[btnRect] != null) {

                            StopCoroutine(activeRotations[btnRect]);

                        }

                    }

                    activeRotations[btnRect] = StartCoroutine(smoothRotateButton(btnRect, targetZ, 0.2f));

                }

            }

            triggerAutoGenerate();

        });

