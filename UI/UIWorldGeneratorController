    void Start() {

        if (biomeGenerator == null) {

            biomeGenerator = FindObjectOfType<BiomeGenerator>();

        }

        if (controlsPanel != null) {

            controlsPanel.SetActive(false);

        }

        saveOriginalValues();

        setupAllSliderListeners();
        setupAllToggleListeners();
        setupFoldButtons();

        setupButtonHover(generateButton, generateHoverTextColor);
        setupButtonHover(resetButton, resetHoverTextColor);
        setupButtonHover(exitButton, exitHoverTextColor);

        setupAutoGenerateButton();

        if (imageOnlyButtons != null) {

            foreach (Button btn in imageOnlyButtons) {

                setupImageButtonHover(btn);

            }

        }

        if (textHoverButtons != null) {

            foreach (Button btn in textHoverButtons) {

                if (btn != autoGenerateButton) {

                    setupTextOnlyButtonHover(btn);

                }

            }

        }

        setupFadeHoverImages();

        if (hyperlinkButtons != null) {

            foreach (HyperlinkButton link in hyperlinkButtons) {

                if (link.button != null) {

                    if (string.IsNullOrEmpty(link.url) == false) {

                        string targetUrl = link.url;
                        
                        link.button.onClick.AddListener(() => {

                            Application.OpenURL(targetUrl);

                        });

                    }

                }

            }

        }

        loadValuesToUI();

        setupInputFormattingEvents();

        refreshAllInputFormats();

        if (generateButton != null) {

            generateButton.onClick.AddListener(generateWorld);

        }

        if (exitButton != null) {

            exitButton.onClick.AddListener(exitApplication);

        }

        if (resetButton != null) {

            resetButton.onClick.AddListener(restoreOriginalValues);

        }

        if (seedInput != null) {

            if (lockSeedToggle != null) {

                seedInput.onEndEdit.AddListener((text) => {

                    lockSeedToggle.isOn = true;

                    triggerAutoGenerate();

                });

            }

        }

        if (lockSeedToggle != null) {

            lockSeedToggle.onValueChanged.AddListener((isLocked) => {

                if (isLocked) {

                    if (seedInput != null) {

                        if (string.IsNullOrEmpty(seedInput.text)) {

                            if (biomeGenerator != null) {

                                seedInput.text = biomeGenerator.seed.ToString();

                            }

                        }

                    }

                }

                triggerAutoGenerate();

            });

        }

        generateWorld();

    }

