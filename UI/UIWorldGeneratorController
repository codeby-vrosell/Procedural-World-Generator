[System.Serializable]
public class StatRowUI {

    [Tooltip("The exact name of the enemy/entity. Ex: 'Frog', 'Trader'")]
    public string targetTileName;
    public TMP_Text totalText;
    public TMP_Text meadowText;
    public TMP_Text forestText;
    public TMP_Text mushroomFText;
    public TMP_Text swampText;
    public TMP_Text ancientRuinsText;

    private int valTotal;
    private int valMeadow;
    private int valForest;
    private int valMushroom;
    private int valSwamp;
    private int valRuins;

    public void resetValues() {

        valTotal = 0;
        valMeadow = 0;
        valForest = 0;
        valMushroom = 0;
        valSwamp = 0;
        valRuins = 0;
        updateText();

    }

    public void addValues(int total, int meadow, int forest, int mushroom, int swamp, int ruins) {

        valTotal = valTotal + total;
        valMeadow = valMeadow + meadow;
        valForest = valForest + forest;
        valMushroom = valMushroom + mushroom;
        valSwamp = valSwamp + swamp;
        valRuins = valRuins + ruins;
        updateText();

    }

    public void setValues(int total, int meadow, int forest, int mushroom, int swamp, int ruins) {

        valTotal = total; 
        valMeadow = meadow; 
        valForest = forest;
        valMushroom = mushroom; 
        valSwamp = swamp; 
        valRuins = ruins;
        updateText();

    }

    private void updateText() {

        if (totalText != null) {

            totalText.text = valTotal.ToString("D2");

        }

        if (meadowText != null) {

            meadowText.text = valMeadow.ToString("D2");

        }

        if (forestText != null) {

            forestText.text = valForest.ToString("D2");

        }

        if (mushroomFText != null) {

            mushroomFText.text = valMushroom.ToString("D2");

        }

        if (swampText != null) {

            swampText.text = valSwamp.ToString("D2");

        }

        if (ancientRuinsText != null) {

            ancientRuinsText.text = valRuins.ToString("D2");

        }
    }
}

