    private void linkToggleToContainers(Toggle toggle, params GameObject[] containers) {

        if (toggle == null) {

            return;

        }

        if (containers == null) {

            return;

        }

        if (containers.Length == 0) {

            return;

        }

        foreach (var container in containers) {

            if (container != null) {

                container.SetActive(toggle.isOn);

