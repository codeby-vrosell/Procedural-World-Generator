    private void generateWorld() {

        if (biomeGenerator == null) { 
            
            return; 
            
        }

        if (GridManager.Instance == null) { 
            
            return; 
            
        }

        if (masterBiomeList == null) { 
            
            return; 
            
        }

        if (lockSeedToggle != null) {

            if (lockSeedToggle.isOn == false) {

                int randomSeed = UnityEngine.Random.Range(int.MinValue, int.MaxValue);

                biomeGenerator.seed = randomSeed;
                
                if (seedInput != null) {

                    seedInput.text = randomSeed.ToString();

                }

            }

            else {

                if (seedInput != null) {

                    if (int.TryParse(seedInput.text, out int parsedSeed)) {

                        biomeGenerator.seed = parsedSeed;

                    }

                }

            }

        }

        else {

            if (seedInput != null) {

                if (int.TryParse(seedInput.text, out int parsedSeed)) {

                    biomeGenerator.seed = parsedSeed;

                }

            }

        }

        biomeGenerator.clearFrameCache();
        biomeGenerator.InitializeOffsets();

        if (biomeSizeInput != null) {

            if (float.TryParse(biomeSizeInput.text, out float parsedSize)) {

                biomeGenerator.approxBiomeSize = parsedSize;

            }

        }

        if (warpNoiseStrengthSlider != null) { 
            
            biomeGenerator.warpStrength = warpNoiseStrengthSlider.value; 
            
        }

        if (warpNoiseFrequencySlider != null) { 
            
            biomeGenerator.warpFrequency = warpNoiseFrequencySlider.value; 
            
        }

        if (falloffNoiseSmoothnessSlider != null) { 
            
            biomeGenerator.falloffSmoothness = falloffNoiseSmoothnessSlider.value; 
            
        }

        if (enableWaterToggle != null) { 
            
            biomeGenerator.enableWater = enableWaterToggle.isOn; 
            
        }

        if (lakeNoiseFrequencySlider != null) { 
            
            biomeGenerator.lakeFrequency = lakeNoiseFrequencySlider.value; 
            
