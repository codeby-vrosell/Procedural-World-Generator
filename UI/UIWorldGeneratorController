    private void updateStatsUI() {

        if (GridManager.Instance == null) {

            return;

        }

        if (masterEnemyRow != null) {

            masterEnemyRow.resetValues();

        }
        
        if (masterEntityRow != null) {

            masterEntityRow.resetValues();

        }
        
        foreach (var row in enemiesStatRows) {

            row.resetValues();

        }
        
        foreach (var row in entitiesStatRows) {

            row.resetValues();

        }

        int masterEnemiesTotal = 0;
        int masterEnemiesMeadow = 0;
        int masterEnemiesForest = 0;
        int masterEnemiesMushroom = 0;
        int masterEnemiesSwamp = 0;
        int masterEnemiesRuins = 0;

        foreach (var kvp in GridManager.Instance.enemyStats) {

            string enemyName = kvp.Key;
            var biomeCounts = kvp.Value;

            int total = 0;
            int meadow = 0;
            int forest = 0;
            int mushroom = 0;
            int swamp = 0;
            int ruins = 0;

            foreach (var biomeData in biomeCounts) {

                string bName = biomeData.Key.ToLower();
                int count = biomeData.Value;
                total = total + count;

                if (bName.Contains("meadow")) {

                    meadow = meadow + count;

                }

                else {

                    if (bName.Contains("forest")) {

                        if (bName.Contains("mushroom") == false) {

                            forest = forest + count;

                        }

                    }

                    else {

                        if (bName.Contains("mushroom")) {

                            mushroom = mushroom + count;

                        }

                        else {

                            if (bName.Contains("swamp")) {

                                swamp = swamp + count;

                            }

                            else {

                                if (bName.Contains("ruin")) {

                                    ruins = ruins + count;

                                }

                            }

                        }

                    }

                }

            }

            StatRowUI row = enemiesStatRows.Find(r =>

                string.IsNullOrEmpty(r.targetTileName) == false && enemyName.ToLower().Contains(r.targetTileName.ToLower())

            );

            if (row != null) {

                row.addValues(total, meadow, forest, mushroom, swamp, ruins);

            }

            masterEnemiesTotal = masterEnemiesTotal + total;
            masterEnemiesMeadow = masterEnemiesMeadow + meadow;
            masterEnemiesForest = masterEnemiesForest + forest;
            masterEnemiesMushroom = masterEnemiesMushroom + mushroom;
            masterEnemiesSwamp = masterEnemiesSwamp + swamp;
            masterEnemiesRuins = masterEnemiesRuins + ruins;

        }

        if (masterEnemyRow != null) {

            masterEnemyRow.setValues(masterEnemiesTotal, masterEnemiesMeadow, masterEnemiesForest, masterEnemiesMushroom, masterEnemiesSwamp, masterEnemiesRuins);

        }

        int masterEntitiesTotal = 0;
        int masterEntitiesMeadow = 0;
        int masterEntitiesForest = 0;
        int masterEntitiesMushroom = 0;
        int masterEntitiesSwamp = 0;
        int masterEntitiesRuins = 0;

        foreach (var kvp in GridManager.Instance.entityStats) {

            string entityName = kvp.Key;

            var biomeCounts = kvp.Value;

            int total = 0;
            int meadow = 0;
            int forest = 0;
            int mushroom = 0;
            int swamp = 0;
            int ruins = 0;

            foreach (var biomeData in biomeCounts) {

                string bName = biomeData.Key.ToLower();

                int count = biomeData.Value;

                total = total + count;

                if (bName.Contains("meadow")) {

                    meadow = meadow + count;

                } 

                else {

                    if (bName.Contains("forest")) {

                        if (bName.Contains("mushroom") == false) {

                            forest = forest + count;

                        }

                    }

                    else {

                        if (bName.Contains("mushroom")) {

                            mushroom = mushroom + count;

                        }

                        else {

                            if (bName.Contains("swamp")) {

                                swamp = swamp + count;

                            } 

                            else {

                                if (bName.Contains("ruin")) {

                                    ruins = ruins + count;

                                }

                            }

                        }

                    }

                }

            }

            StatRowUI row = entitiesStatRows.Find(r => string.IsNullOrEmpty(r.targetTileName) == false && entityName.ToLower().Contains(r.targetTileName.ToLower()));

            if (row != null) {

                row.addValues(total, meadow, forest, mushroom, swamp, ruins);

            }

            masterEntitiesTotal = masterEntitiesTotal + total;
            masterEntitiesMeadow = masterEntitiesMeadow + meadow;
            masterEntitiesForest = masterEntitiesForest + forest;
